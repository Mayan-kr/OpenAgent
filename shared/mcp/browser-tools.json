{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "OpenAgent Browser Tool Contract",
  "description": "The stable, transport-neutral contract between the extension capability host and MCP clients.",
  "tools": [
    {
      "name": "browser.get_current_page",
      "safety": "read_only",
      "inputSchema": { "type": "object", "properties": {} },
      "outputSchema": { "$ref": "#/$defs/pageContext" }
    },
    {
      "name": "browser.request_action",
      "safety": "requires_user_approval",
      "inputSchema": {
        "type": "object",
        "required": ["action", "reason"],
        "properties": {
          "action": { "type": "string", "enum": ["click", "type", "navigate"] },
          "reason": { "type": "string", "minLength": 1, "maxLength": 500 },
          "target": { "type": "string", "maxLength": 500 }
        }
      }
    },
    {
      "name": "browser.get_dom_snapshot",
      "safety": "read_only",
      "inputSchema": { "type": "object", "properties": {} },
      "outputSchema": { "$ref": "#/$defs/domSnapshot" }
    }
  ],
  "$defs": {
    "pageContext": {
      "type": "object",
      "required": ["url", "title", "text", "selectedText", "interactiveElements"],
      "properties": {
        "url": { "type": "string", "format": "uri" },
        "title": { "type": "string", "maxLength": 500 },
        "text": { "type": "string", "maxLength": 12000 },
        "selectedText": { "type": "string", "maxLength": 4000 },
        "interactiveElements": { "type": "array", "maxItems": 80 },
        "dom": { "$ref": "#/$defs/domSnapshot" }
      }
    },
    "domSnapshot": {
      "type": "object",
      "required": ["landmarks", "headings", "forms", "tables", "tree"],
      "properties": {
        "landmarks": { "type": "array", "maxItems": 30 },
        "headings": { "type": "array", "maxItems": 100 },
        "forms": { "type": "array", "maxItems": 30 },
        "tables": { "type": "array", "maxItems": 30 },
        "tree": { "type": "array", "maxItems": 200 }
      }
    }
  }
}
